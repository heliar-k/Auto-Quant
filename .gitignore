# results journal — untracked by design so experience survives `git reset`
results.tsv
# but DO track frozen snapshots under versions/
!versions/**/results.tsv

# run logs — every experiment writes run.log, never commit
run.log
*.log
# but DO track frozen run-log snapshots under versions/
!versions/**/run.log
!versions/**/*.log

# FreqTrade-generated output
user_data/data/
user_data/backtest_results/
user_data/logs/
user_data/hyperopt_results/
user_data/notebooks/.ipynb_checkpoints/

# Python / uv
__pycache__/
*.pyc
.venv/
.python-version.lock

# Editor / OS
.DS_Store
.vscode/
.idea/
*.swp

# Jupyter
.ipynb_checkpoints/
